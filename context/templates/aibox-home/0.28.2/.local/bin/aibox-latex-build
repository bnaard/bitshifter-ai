#!/bin/sh
# aibox-managed:latex-container-script
# Build one configured LaTeX document, or all documents when omitted.
set -eu

workspace=${AIBOX_WORKSPACE:-/workspace}
cd "$workspace"
export TEXMFVAR="$workspace/.latex-cache/texmf-var"
export TEXMFCONFIG="$workspace/.latex-cache/texmf-config"

prepare() {
  source_path=$1
  output_dir=$2
  if [ ! -f "$workspace/$source_path" ]; then
    printf 'LaTeX source does not exist: %s\n' "$workspace/$source_path" >&2
    exit 1
  fi
  mkdir -p "$workspace/$output_dir" "$TEXMFVAR" "$TEXMFCONFIG"
}

build_0() {
  prepare 'doc/overview/overview.tex' 'doc/overview/out'
  printf '%s\n' 'Building LaTeX document '\''overview'\'''
  'latexmk' '-lualatex' '-interaction=nonstopmode' '-halt-on-error' '-file-line-error' '-outdir=doc/overview/out' 'doc/overview/overview.tex'
}

build_1() {
  prepare 'doc/theory/book.tex' 'doc/theory/out'
  printf '%s\n' 'Building LaTeX document '\''theory'\'''
  'latexmk' '-lualatex' '-interaction=nonstopmode' '-halt-on-error' '-file-line-error' '-outdir=doc/theory/out' 'doc/theory/book.tex'
}

case "${1:-all}" in
  all)
    build_0
    build_1
    ;;
  'overview') build_0 ;;
  'theory') build_1 ;;
  *) printf 'Unknown LaTeX document: %s\nConfigured documents: %s\n' "${1:-}" 'overview, theory' >&2; exit 2 ;;
esac
