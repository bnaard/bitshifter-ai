#!/bin/sh
# aibox-managed:latex-container-script
# Continuously rebuild one configured LaTeX document in this container.
set -eu

workspace=${AIBOX_WORKSPACE:-/workspace}
cd "$workspace"
export TEXMFVAR="$workspace/.latex-cache/texmf-var"
export TEXMFCONFIG="$workspace/.latex-cache/texmf-config"

prepare() {
  source_path=$1
  output_dir=$2
  if [ ! -f "$workspace/$source_path" ]; then
    printf 'LaTeX source does not exist: %s\n' "$workspace/$source_path" >&2
    exit 1
  fi
  mkdir -p "$workspace/$output_dir" "$TEXMFVAR" "$TEXMFCONFIG"
}

document=${1:-''}
case "$document" in
  'overview')
    prepare 'doc/overview/overview.tex' 'doc/overview/out'
    printf '%s\n' 'Watching LaTeX document '\''overview'\'' (Ctrl-C to stop)'
    exec 'latexmk' '-lualatex' '-interaction=nonstopmode' '-halt-on-error' '-file-line-error' '-outdir=doc/overview/out' '-pvc' '-view=none' 'doc/overview/overview.tex'
    ;;
  'theory')
    prepare 'doc/theory/book.tex' 'doc/theory/out'
    printf '%s\n' 'Watching LaTeX document '\''theory'\'' (Ctrl-C to stop)'
    exec 'latexmk' '-lualatex' '-interaction=nonstopmode' '-halt-on-error' '-file-line-error' '-outdir=doc/theory/out' '-pvc' '-view=none' 'doc/theory/book.tex'
    ;;
  *) printf 'Unknown LaTeX document: %s\nConfigured documents: %s\n' "${1:-}" 'overview, theory' >&2; exit 2 ;;
esac
